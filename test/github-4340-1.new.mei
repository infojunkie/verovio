                                 </verse>
                                 <verse xml:id="d1okgyz2" n="2">
                                    <syl xml:id="e1hv1d8y" con="s" wordpos="s">Der Herr ist mein</syl>
                                 </verse>
                                 <verse xml:id="gpx1c2n" n="3">
                                    <syl xml:id="hf0xux4" con="s" wordpos="s">dein Stecken und Stab</syl>
